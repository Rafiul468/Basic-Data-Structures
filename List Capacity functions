//myListempty()

#include <bits/stdc++.h>
using namespace std;
int main()
{
    vector<int> v = {10,20,30};
    list<int>l(v.begin(), v.end());

    l.clear();
    if(l.empty())
    {
        cout<<"Empty";
    }
    for(int val:l)
    {
        cout<<val<<endl;
    }
    return 0;
}





