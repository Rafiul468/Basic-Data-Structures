//myList.remove(V)

#include <bits/stdc++.h>
using namespace std;
int main()
{
    list<int> l = {10,20,30,40,10,60,10,80,90,10};

    l.remove(10);
    for(int val:l)
    {
        cout<<val<<endl;
    }
    return 0;
}





